  "fieldGroups": [
    {
      "id": "shape",
      "title": "キーキャップの形",
      "description": "キーキャップ全体の大きさと、上に向かって細くなる具合を調整します。キーサイズは横幅と連動していて、18 mm を 1u として換算します。",
      "fieldKeys": ["shapeProfile", "keyWidth", "keyDepth", "wallThickness", "topScale", "bodyColor"]
    },
    {
      "id": "top",
      "title": "キートップ",
      "description": "上面中央の基準高さを固定したまま、フラット / シンドリカル / スフェリカルを切り替えられます。シンドリカルは一方向だけ曲がります。端の高さに切り替えた場合も内部では pitch / roll に正規化されます。",
      "fieldKeys": ["topCenterHeight", "topSurfaceShape", "dishDepth", "topSlopeInputMode", "topPitchDeg", "topRollDeg", "topFrontHeight", "topBackHeight", "topLeftHeight", "topRightHeight"]
    },
    {
      "id": "legend",
      "title": "印字",
      "description": "入れる文字、書体、見た目、位置、盛り上がり、埋め込み量をまとめて調整します。複数文字もそのまま入力できます。",
      "fieldKeys": ["legendEnabled", "legendColor", "legendText", "legendFontKey", "legendFontStyleKey", "legendUnderlineEnabled", "legendSize", "legendOutlineDelta", "legendHeight", "legendEmbed", "legendOffsetX", "legendOffsetY"]
    },
    {
      "id": "homing",
      "title": "指の目印",
      "description": "F キーや J キーのように、指で触って分かる出っ張りを調整します。印字とは別に設定できます。",
      "fieldKeys": ["homingBarEnabled", "homingBarColor", "homingBarLength", "homingBarWidth", "homingBarHeight", "homingBarChamfer", "homingBarOffsetY"]
    },
    {
      "id": "stem",
      "title": "取り付け部分",
      "descriptionKey": "stem-group",
      "fieldKeys": ["stemType", "stemOuterDelta", "stemCrossMargin", "stemInsetDelta"]
    }
  ]
}
