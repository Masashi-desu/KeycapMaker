{
  "key": "custom-shell",
  "label": "カスタムシェル",
  "geometryType": "shell",
  "geometryDefaults": {
    "profileFrontAngle": 15,
    "profileBackAngle": 15,
    "profileLeftAngle": 10,
    "profileRightAngle": 10,
    "topThickness": 1.5,
    "bottomCornerRadius": 1.0,
    "topCornerRadius": 1.5
  },
  "defaults": {
    "name": "keycap-preview",
    "shapeProfile": "custom-shell",
    "keyWidth": 18,
    "keyDepth": 18,
    "topCenterHeight": 9.5,
    "topSlopeInputMode": "angle",
    "topPitchDeg": 0,
    "topRollDeg": 0,
    "wallThickness": 1.2,
    "topScale": 0.84,
    "topSurfaceShape": "flat",
    "dishRadius": 45,
    "dishDepth": 0,
    "bodyColor": "#f8f9fa",
    "legendEnabled": true,
    "legendText": "A",
    "legendFontKey": "mplus1-variable",
    "legendFontStyleKey": "regular",
    "legendUnderlineEnabled": false,
    "legendSize": 5.0,
    "legendOutlineDelta": 0,
    "legendHeight": 0,
    "legendEmbed": 0.6,
    "legendColor": "#212529",
    "legendOffsetX": 0,
    "legendOffsetY": 0,
    "homingBarEnabled": true,
    "homingBarLength": 4.0,
    "homingBarWidth": 1.58,
    "homingBarHeight": 0.6,
    "homingBarChamfer": 0.3,
    "homingBarOffsetY": -3.5,
    "homingBarColor": "#ff7f00",
    "stemType": "choc_v2",
    "stemOuterDelta": 0,
    "stemCrossMargin": 0,
    "stemInsetDelta": 0
